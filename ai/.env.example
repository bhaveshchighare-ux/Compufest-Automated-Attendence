ENV=production

# Internal API key (keep as-is for production)
API_KEY=production-dev-key

# NeonDB / PostgreSQL connection string
DATABASE_URL=postgresql://<user>:<password>@<host>/<database>?sslmode=require

# RedisLabs / Upstash Redis URL
REDIS_URL=redis://default:<password>@<host>:<port>

# Gemini API key for LLM inference
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-1.5-flash

# Number of interview questions to generate
NUMBER_OF_QUESTIONS=6
MAX_QUESTIONS=8

# Server configuration
PORT=8000
LOG_LEVEL=INFO

# LLM Configuration
LLM_PROVIDER=huggingface
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=
HF_TOKEN=

# Interview session TTL
INTERVIEW_SESSION_TTL_SECONDS=3600
