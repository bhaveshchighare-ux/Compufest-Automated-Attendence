# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Database
MONGO_URI=mongodb://127.0.0.1:27017/mockprep

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE=7d

# Interview AI service
AI_API_BASE_URL=http://localhost:8000
AI_API_KEY=replace-with-ai-service-api-key

# Dashboard feedback provider
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Email OTP delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password
SMTP_FROM=MockPrep.ai <your_email@gmail.com>

# Plan Credits
FREE_PLAN_CREDITS=2
PRO_PLAN_CREDITS=15
PREMIUM_PLAN_CREDITS=30

# Razorpay Configuration
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=
RAZORPAY_PRO_PLAN_ID=
RAZORPAY_PREMIUM_PLAN_ID=
RAZORPAY_WEBHOOK_SECRET=

# QStash Configuration
QSTASH_TOKEN=
QSTASH_URL=
QSTASH_WEBHOOK_SECRET=

# Webhook call-back URL
BACKEND_URL=http://localhost:5000

# Additional AI Models
GEMINI_MODEL=
XAI_API_KEY=
XAI_MODEL=
GROK_API_KEY=
GROK_MODEL=
